# /etc/coa/excludes.list
# Modern template for coa/oa remastering
# Author: Piero Proietti (Based on historical refractasnapshot lists)

# --- Caches & Logs (Heavy & Unneeded) ---
var/cache/*
var/tmp/*
var/log/*.log
var/log/*.log.?
var/log/*/*
*.cache

# --- Package Manager Leftovers ---
var/lib/apt/lists/*
var/lib/apt/cache/*
var/lib/dpkg/*~old
home/*/.local/share/yay

# --- Snapshots, Backups & Swap ---
.snapshots/*
timeshift
var/backups/*
swapfile
swap/*
lost+found

# --- Hardware / Boot (Regenerated dynamically) ---
boot/*rescue*
boot/grub/grub.cfg
boot/grub/device.map
etc/blkid.tab
etc/crypttab
etc/udev/rules.d/70-persistent-net.rules
etc/udev/rules.d/70-persistent-cd.rules